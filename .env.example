# Copy to .env and adjust.

# ---- Database ----
# Local Postgres via unix socket (macOS Homebrew default):
DATABASE_URL="postgresql://USER@localhost/peacock?host=/tmp"
# Local Postgres via TCP:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/peacock"
# Neon / hosted Postgres (TLS auto-enabled when the URL is remote):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/peacock?sslmode=require"

# ---- Auth ----
# Long random secret used to sign the session JWT.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-secret"

# ---- App ----
# Public base URL used when building share links.
# Local: http://localhost:3000  |  Vercel: your deployment URL (auto-detected if unset).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
